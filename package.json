{
  "name": "baileys-monorepo",
  "private": true,
  "type": "module",
  "description": "Monorepo for the Baileys WhatsApp Web library and its WebAssembly bridge",
  "homepage": "https://github.com/WhiskeySockets/Baileys/",
  "repository": {
    "url": "git@github.com:WhiskeySockets/Baileys.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "build:baileys": "pnpm --filter baileys build",
    "build:bridge": "pnpm --filter whatsapp-rust-bridge build",
    "test": "pnpm --filter baileys test",
    "test:e2e": "pnpm --filter baileys test:e2e",
    "lint": "pnpm --filter baileys lint",
    "lint:fix": "pnpm --filter baileys lint:fix",
    "format": "pnpm --filter baileys format",
    "example": "pnpm --filter baileys example"
  },
  "pnpm": {
    "overrides": {
      "ajv@^6.12.4": "^6.14.0",
      "basic-ftp": "^5.2.4",
      "brace-expansion@^1.1.7": "^1.1.13",
      "brace-expansion@^2.0.1": "^2.0.3",
      "flatted": "^3.4.2",
      "glob@^10.2.2": "^10.5.0",
      "glob@^10.3.10": "^10.5.0",
      "glob@^10.5.0": "^10.5.0",
      "handlebars": "^4.7.9",
      "ip-address": "^10.1.1",
      "js-yaml@^3.13.1": "^3.14.2",
      "js-yaml@^4.1.0": "^4.1.1",
      "markdown-it": "^14.1.1",
      "minimatch@^3.0.4": "^3.1.5",
      "minimatch@^3.1.2": "^3.1.5",
      "minimatch@^5.0.1": "^5.1.8",
      "minimatch@^9.0.4": "^9.0.9",
      "minimatch@^9.0.5": "^9.0.9",
      "picomatch@^2.0.4": "^2.3.2",
      "picomatch@^2.3.1": "^2.3.2",
      "picomatch@^4.0.0": "^4.0.4",
      "picomatch@^4.0.2": "^4.0.4",
      "socks": "^2.8.8",
      "tar": "^7.5.11",
      "tmp": "^0.2.5",
      "underscore": "^1.13.8",
      "yaml@^2.6.1": "^2.8.4"
    }
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
